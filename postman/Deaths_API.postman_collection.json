  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "const tokenExpiry = pm.environment.get(\"token_expiry\");\r",
          "const accessToken = pm.environment.get(\"access_token\");\r",
          "const hasToken = accessToken && accessToken.length > 0;\r",
          "const isExpired = !tokenExpiry || Date.now() > parseInt(tokenExpiry);\r",
          "\r",
          "if (!hasToken || isExpired) {\r",
          "    pm.sendRequest({\r",
          "        url: pm.environment.get(\"base_url\") + \"/auth/token\",\r",
          "        method: \"POST\",\r",
          "        header: { \"Content-Type\": \"application/json\" },\r",
          "        body: {\r",
          "            mode: \"raw\",\r",
          "            raw: JSON.stringify({\r",
          "                username: \"admin\",\r",
          "                password: \"change_me1234\"\r",
          "            })\r",
          "        }\r",
          "    }, (error, response) => {\r",
          "        if (error) {\r",
          "            console.error(\"Auth failed:\", error);\r",
          "            return;\r",
          "        }\r",
          "        const body = response.json();\r",
          "        pm.environment.set(\"access_token\", body.access_token);\r",
          "        pm.environment.set(\"token_expiry\", Date.now() + 25 * 60 * 1000);\r",
          "    })\r",
          "}"
        ]
      }
    },
