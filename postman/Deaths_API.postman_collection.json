      "name": "Auth",
      "item": [
        {
          "name": "Login - valid credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Returns access token\", () => {\r",
                  "    const body = pm.response.json();\r",
                  "    pm.expect(body.access_token).to.be.a(\"string\");\r",
                  "    pm.expect(body.access_token.length).to.be.greaterThan(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Returns refresh token\", () => {\r",
                  "    const body = pm.response.json();\r",
                  "    pm.expect(body.refresh_token).to.be.a(\"string\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Token type is bearer\", () => {\r",
                  "    pm.expect(pm.response.json().token_type).to.equal(\"bearer\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Expires in 1800 seconds\", () => {\r",
                  "    pm.expect(pm.response.json().expires_in).to.equal(1800);\r",
                  "});\r",
                  "\r",
                  "// Store token for use in other requests\r",
                  "const body = pm.response.json();\r",
                  "pm.collectionVariables.set(\"access_token\", body.access_token);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
